node_modules/
screenshots/
scripts/layout_manifest_tmp.json
scripts/crop_manifest_tmp.json
scripts/indicator_manifest_tmp.json
scripts/alerts_manifest_tmp.json
desktop.ini
logs/*.log
logs/*.json
logs/*.md
scripts/*_tmp.json
scripts/__pycache__/
__pycache__/

# Generated by build_review_deck.py (served by the pipeline app)
scripts/pipeline_app/review_deck.html
scripts/pipeline_app/review_deck_summary.json
scripts/pipeline_app/_annotated_charts/

# Generated by render_architecture_html.py (in-app deck views)
scripts/dashboard_app/architecture.html
scripts/dashboard_app/alert_rules.html

# Git worktrees live under .claude/worktrees in the working copy - never track them
.claude/worktrees/

# Per-run history archive (machine data, appended by history_store.py)
data/history.db

# Per-machine run state (data as-of dates, stage timings)
data/ingestion_state.json
data/stage_timings.json

# Investment-analyst per-run image QA output (regenerated each analysis run)
scripts/analyst_image_issues.json

# Investment Dashboard (Phase 1 build) — generated data + local server data
scripts/dashboard_app/data/

# Generated by spending_summary.py (share-dividend figures for the dashboard)
data/spending_dividends.json

# Dedicated Chrome profile the dashboard launcher opens in (scripts/dashboard_open.js) —
# a whole browser profile: caches, cookies, service workers. Machine-local, never committed.
data/dashboard-chrome-profile/

# Google service-account key, if it is ever placed in-tree by mistake.
# It normally lives OUTSIDE the repo (~/.secrets/) because the repo syncs to OneDrive.
*service-account*.json
*-sheets-sync.json
