{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch TradingView (debug port)",
      "type": "shell",
      "command": "${workspaceFolder}\\scripts\\launch_tv_debug.bat",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Export Layouts to Excel",
      "type": "shell",
      "command": "npm run export:layouts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
